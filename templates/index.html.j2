<!doctype html>
<html lang="vi">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Tất cả bản tin · {{ brand }}</title>
  <style>
    body{margin:0;background:#f4ecdc;color:#102235;font-family:Arial,sans-serif}
    main{max-width:980px;margin:0 auto;padding:36px 18px}
    h1{font-family:Georgia,serif;font-size:clamp(34px,6vw,72px);line-height:1;margin:0 0 24px;color:#071b2d}
    a{color:#071b2d;text-decoration:none}
    .latest{display:inline-block;background:#071b2d;color:#f8f1e4;padding:12px 16px;border-radius:6px;margin-bottom:24px}
    .item{border-top:1px solid #d6c29c;padding:16px 0;display:flex;gap:18px;justify-content:space-between}
    .item span{color:#9b6b20;font-weight:700}
  </style>
</head>
<body>
  <main>
    <h1>{{ brand }} Research</h1>
    {% if latest_file %}<a class="latest" href="{{ latest_file }}">Mở bản tin mới nhất</a>{% endif %}
    {% for item in items %}
    <article class="item">
      <a href="{{ item.href }}">{{ item.title }}</a>
      <span>{{ item.date }}</span>
    </article>
    {% endfor %}
  </main>
</body>
</html>
