# Primary AI writer. Add the real value in GitHub Secrets, not in this file.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Optional fallback AI writer.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Runtime knobs.
LOOKBACK_DAYS=10
REQUEST_TIMEOUT=12
REQUEST_RETRIES=3
REPORTS_DIR=reports
PUBLIC_DIR=public
TEMPLATE_PATH=templates/report.html.j2
