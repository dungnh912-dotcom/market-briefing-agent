# Optional. Used by src/fetch_news.py when available.
NEWSAPI_KEY=

# Optional. If set, src/llm.py can call OpenAI-compatible chat completions.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional. GitHub Actions provides GITHUB_TOKEN automatically. With
# permissions: models: read, it can be used against GitHub Models.
GITHUB_TOKEN=
GITHUB_MODEL=openai/gpt-4.1-mini

# Runtime knobs.
LOOKBACK_DAYS=180
REPORT_LANGUAGE=vi
